// server/routes/intakes.ts
import { Router, Request, Response } from 'express';
import fs from 'fs';
import path from 'path';
import { DATA_DIR } from '../paths';

const router = Router();

const INTAKES_DIR = path.join(DATA_DIR, 'intakes');

interface IntakeMeta {
  id: string;
  createdAt: string;
  goal: string;
  notes?: string;
  textContext?: string;
  assets: Array<{
    id: string;
    kind: 'image' | 'audio' | 'file' | 'screenshot' | 'screenCapture';
    filename: string;
    mimeType: string;
    size: number;
  }>;
}

function safeId(id: string): boolean {
  return /^[a-zA-Z0-9_-]+$/.test(id);
}

function readMeta(intakeDir: string): IntakeMeta | null {
  const metaPath = path.join(intakeDir, 'meta.json');
  if (!fs.existsSync(metaPath)) return null;
  try {
    return JSON.parse(fs.readFileSync(metaPath, 'utf-8'));
  } catch {
    return null;
  }
}

// GET /api/intakes - list recent intakes (newest first)
router.get('/', (_req: Request, res: Response) => {
  if (!fs.existsSync(INTAKES_DIR)) {
    res.json({ intakes: [] });
    return;
  }

  const dirs = fs
    .readdirSync(INTAKES_DIR, { withFileTypes: true })
    .filter((d) => d.isDirectory())
    .map((d) => d.name);

  const records = dirs
    .map((id) => readMeta(path.join(INTAKES_DIR, id)))
    .filter((m): m is IntakeMeta => m !== null)
    .sort((a, b) => (a.createdAt < b.createdAt ? 1 : -1));

  // Summary view: trim heavy fields
  const summary = records.map((m) => ({
    id: m.id,
    createdAt: m.createdAt,
    goal: m.goal,
    assetCount: m.assets.length,
    assetBreakdown: m.assets.reduce<Record<string, number>>((acc, a) => {
      acc[a.kind] = (acc[a.kind] ?? 0) + 1;
      return acc;
    }, {}),
  }));

  res.json({ intakes: summary });
});

// GET /api/intakes/:id - full detail
router.get('/:id', (req: Request, res: Response) => {
  const id = req.params.id;
  if (!safeId(id)) {
    res.status(400).json({ error: 'Invalid intake id' });
    return;
  }

  const meta = readMeta(path.join(INTAKES_DIR, id));
  if (!meta) {
    res.status(404).json({ error: 'Intake not found' });
    return;
  }

  // Attach URL references for each asset
  const assets = meta.assets.map((a) => ({
    ...a,
    url: `/api/intakes/${id}/assets/${a.id}`,
  }));

  res.json({ intake: { ...meta, assets } });
});

// GET /api/intakes/:id/assets/:assetId - serve raw asset
router.get('/:id/assets/:assetId', (req: Request, res: Response) => {
  const { id, assetId } = req.params;
  if (!safeId(id) || !safeId(assetId)) {
    res.status(400).json({ error: 'Invalid id' });
    return;
  }

  const meta = readMeta(path.join(INTAKES_DIR, id));
  if (!meta) {
    res.status(404).json({ error: 'Intake not found' });
    return;
  }

  const asset = meta.assets.find((a) => a.id === assetId);
  if (!asset) {
    res.status(404).json({ error: 'Asset not found' });
    return;
  }

  const filePath = path.join(INTAKES_DIR, id, asset.filename);
  if (!fs.existsSync(filePath)) {
    res.status(404).json({ error: 'Asset file missing' });
    return;
  }

  res.setHeader('Content-Type', asset.mimeType || 'application/octet-stream');
  fs.createReadStream(filePath).pipe(res);
});

export default router;
