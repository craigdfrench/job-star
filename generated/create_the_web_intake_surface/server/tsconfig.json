import { promises as fs } from 'node:fs';
import path from 'node:path';
import { randomBytes } from 'node:crypto';
import { createWriteStream } from 'node:fs';
import { pipeline } from 'node:stream/promises';
import type { Readable } from 'node:stream';

export interface StoredAsset {
  /** Stable filename used on disk, e.g. `screenshot-1.png`. */
  filename: string;
  /** Original client-provided name. */
  originalName: string;
  /** MIME type from the upload. */
  mimeType: string;
  /** Size in bytes. */
  size: number;
  /** Logical role: screenshot | voice | file | unknown. */
  role: 'screenshot' | 'voice' | 'file' | 'unknown';
  /** Relative path from the intakes root, e.g. `intake_x/screenshot-1.png`. */
  relativePath: string;
}

export interface IntakeSubmission {
  id: string;
  clientSubmissionId?: string;
  createdAt: string;
  title: string;
  description?: string;
  jobUrl?: string;
  company?: string;
  role?: string;
  tags: string[];
  metadata: Record<string, unknown>;
  assets: StoredAsset[];
}

const INTAKES_ROOT = path.resolve(process.cwd(), 'intakes');

/** Classify an upload into a logical role by mime type + fieldname. */
function classifyAsset(fieldname: string, mimeType: string): StoredAsset['role'] {
  const m = mimeType.toLowerCase();
  const f = fieldname.toLowerCase();
  if (f.includes('screenshot') || m.startsWith('image/')) return 'screenshot';
  if (f.includes('voice') || f.includes('audio') || m.startsWith('audio/')) return 'voice';
  if (f.includes('file')) return 'file';
  return 'unknown';
}

/** Build a safe disk filename from an original name. */
function safeBaseName(original: string): string {
  const ext = path.extname(original) || '';
  const base = path.basename(original, ext).replace(/[^a-zA-Z0-9-_]/g, '_').slice(0, 40) || 'asset';
  return `${base}${ext.toLowerCase()}`;
}

export class IntakeStore {
  constructor(private readonly rootDir: string = INTAKES_ROOT) {}

  async ensureRoot(): Promise<void> {
    await fs.mkdir(this.rootDir, { recursive: true });
  }

  /** Generate a new submission id. */
  newId(): string {
    const ts = Date.now().toString(36);
    const rand = randomBytes(4).toString('hex');
    return `intake_${ts}_${rand}`;
  }

  /** Resolve a submission directory, creating it if needed. */
  private async submissionDir(id: string): Promise<string> {
    const dir = path.join(this.rootDir, id);
    await fs.mkdir(dir, { recursive: true });
    return dir;
  }

  /** Persist a single uploaded file buffer/stream to the submission dir. */
  async writeAsset(
    submissionId: string,
    file: { originalname: string; mimetype: string; size: number; buffer?: Buffer; stream?: Readable },
    fieldname: string,
    index: number,
  ): Promise<StoredAsset> {
    const dir = await this.submissionDir(submissionId);
    const role = classifyAsset(fieldname, file.mimetype);
    const base = safeBaseName(file.originalname);
    const filename = `${role}-${index}-${base}`;
    const fullPath = path.join(dir, filename);

    if (file.buffer) {
      await fs.writeFile(fullPath, file.buffer);
    } else if (file.stream) {
      await pipeline(file.stream, createWriteStream(fullPath));
    } else {
      throw new Error('Asset has neither buffer nor stream');
    }

    return {
      filename,
      originalName: file.originalname,
      mimeType: file.mimetype,
      size: file.size,
      role,
      relativePath: path.relative(this.rootDir, fullPath),
    };
  }

  /** Write the submission.json manifest. */
  async writeManifest(submission: IntakeSubmission): Promise<string> {
    const dir = await this.submissionDir(submission.id);
    const manifestPath = path.join(dir, 'submission.json');
    await fs.writeFile(manifestPath, JSON.stringify(submission, null, 2), 'utf8');
    return manifestPath;
  }

  /** Check whether a submission id already exists on disk. */
  async exists(id: string): Promise<boolean> {
    try {
      const stat = await fs.stat(path.join(this.rootDir, id, 'submission.json'));
      return stat.isFile();
    } catch {
      return false;
    }
  }

  /** List all submission ids (sorted newest-first by directory mtime). */
  async list(): Promise<string[]> {
    try {
      const entries = await fs.readdir(this.rootDir, { withFileTypes: true });
      const dirs = entries.filter((e) => e.isDirectory()).map((e) => e.name);
      const stamped = await Promise.all(
        dirs.map(async (name) => {
          const st = await fs.stat(path.join(this.rootDir, name));
          return { name, mtime: st.mtimeMs };
        }),
      );
      return stamped.sort((a, b) => b.mtime - a.mtime).map((s) => s.name);
    } catch {
      return [];
    }
  }

  /** Read a manifest by id. */
  async read(id: string): Promise<IntakeSubmission | null> {
    try {
      const raw = await fs.readFile(path.join(this.rootDir, id, 'submission.json'), 'utf8');
      return JSON.parse(raw) as IntakeSubmission;
    } catch {
      return null;
    }
  }
}

export const intakeStore = new IntakeStore();
