{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"]
  },
  "include": ["server", "../shared/src"],
  "references": [{ "path": "../shared" }]
}


// --- DUPLICATE BLOCK ---

/**
 * Job-Star local intake server.
 *
 * A lightweight Express app that accepts rich intake payloads:
 * screenshots, voice recordings, file uploads, and visual context metadata.
 *
 * Runs locally on http://localhost:4319 — a memorable port for "JS" (J=4th letter, S=19th).
 */

import express, { Request, Response, NextFunction } from "express";
import cors from "cors";
import multer from "multer";
import path from "node:path";
import fs from "node:fs";
import { nanoid } from "nanoid";
import type { IntakePayload, IntakeAck, ApiError } from "@job-star/shared";

const PORT = Number(process.env.JOB_STAR_PORT ?? 4319);
const STORAGE_DIR = path.resolve(
  process.env.JOB_STAR_STORAGE ?? path.join(process.cwd(), "..", "storage"),
);

// Ensure storage subdirs exist
const SUBDIRS = ["screenshots", "voice", "files"] as const;
for (const dir of SUBDIRS) {
  fs.mkdirSync(path.join(STORAGE_DIR, dir), { recursive: true });
}

const app = express();

app.use(cors());
app.use(express.json({ limit: "5mb" }));

// --- Multer config: store uploads into categorized subdirs -------------------
const storage = multer.diskStorage({
  destination: (_req, file, cb) => {
    let subdir = "files";
    if (file.mimetype.startsWith("image/")) subdir = "screenshots";
    else if (file.mimetype.startsWith("audio/")) subdir = "voice";
    cb(null, path.join(STORAGE_DIR, subdir));
  },
  filename: (_req, file, cb) => {
    const ext = path.extname(file.originalname) || "";
    cb(null, `${nanoid(12)}${ext}`);
  },
});

const upload = multer({
  storage,
  limits: { fileSize: 50 * 1024 * 1024 }, // 50MB per file
});

// --- Health check -----------------------------------------------------------
app.get("/api/health", (_req: Request, res: Response) => {
  res.json({ status: "ok", service: "job-star-intake", version: "0.1.0" });
});

// --- Intake submission ------------------------------------------------------
// Accepts multipart/form-data:
//   - field "payload": JSON-encoded IntakePayload (without asset binary)
//   - field "screenshots": file(s)
//   - field "voice": file(s)
//   - field "files": file(s)
app.post(
  "/api/intake",
  upload.fields([
    { name: "screenshots", maxCount: 20 },
    { name: "voice", maxCount: 10 },
    { name: "files", maxCount: 20 },
  ]),
  (req: Request, res: Response) => {
    let payload: IntakePayload;
    try {
      payload = JSON.parse(req.body.payload as string) as IntakePayload;
    } catch {
      const err: ApiError = { error: "invalid_payload", detail: "Could not parse JSON payload field." };
      return res.status(400).json(err);
    }

    // Attach uploaded file metadata to the payload so downstream consumers
    // know what actually landed on disk.
    const files = (req.files as Record<string, Express.Multer.File[]>) ?? {};
    const countFiles = (key: string) => files[key]?.length ?? 0;

    const receivedAssetCount =
      countFiles("screenshots") + countFiles("voice") + countFiles("files");

    const ack: IntakeAck = {
      id: payload.id || nanoid(),
      accepted: true,
      receivedAssetCount,
      message: `Intake received with ${receivedAssetCount} asset(s).`,
    };

    // Persist a copy of the payload JSON alongside assets for replay/debug.
    const intakeDir = path.join(STORAGE_DIR, "intakes");
    fs.mkdirSync(intakeDir, { recursive: true });
    fs.writeFileSync(
      path.join(intakeDir, `${ack.id}.json`),
      JSON.stringify({ ...payload, ...ack, receivedFiles: files }, null, 2),
    );

    console.log(`[intake] ${ack.id} — ${ack.message}`);
    res.status(201).json(ack);
  },
);

// --- Error handler ----------------------------------------------------------
app.use((err: Error, _req: Request, res: Response, _next: NextFunction) => {
  console.error("[server error]", err);
  const body: ApiError = { error: "server_error", detail: err.message };
  res.status(500).json(body);
});

app.listen(PORT, () => {
  console.log(`Job-Star intake server listening on http://localhost:${PORT}`);
  console.log(`Storage dir: ${STORAGE_DIR}`);
});


