# =============================================================================
# Job-Star environment configuration
# =============================================================================
# Copy this file to `.env` and adjust values for your environment.
# All variables are optional; defaults are defined in
# src/job_star/constants.py.
#
# Variable prefixes:
#   JOB_STAR_        top-level settings (mode, timeouts, shutdown)
#   JOB_STAR__<sub>__<key>  nested sub-settings via "__" delimiter
#   GATEHOUSE_       gatehouse connection & auth
#   POLLING_         polling loop behavior
#   CONCURRENCY_     concurrency limits
#   RETRY_           retry behavior
#   LOG_             logging
# =============================================================================


# -----------------------------------------------------------------------------
# Top-level Job-Star settings
# -----------------------------------------------------------------------------
# How Job-Star obtains jobs: polling | listening | hybrid
JOB_STAR_MODE=polling

# Hard ceiling on wait time per job (seconds)
JOB_STAR_JOB_COMPLETION_TIMEOUT_SECONDS=3600

# Grace period before cancelling in-flight jobs on shutdown (seconds)
JOB_STAR_SHUTDOWN_GRACE_SECONDS=30


# -----------------------------------------------------------------------------
# Gatehouse connection
# -----------------------------------------------------------------------------
GATEHOUSE_ENDPOINT=http://localhost:8000
GATEHOUSE_API_VERSION=v1
GATEHOUSE_HEALTH_PATH=/healthz

# Auth scheme used in the Authorization header (Bearer, Token, etc.)
GATEHOUSE_AUTH_SCHEME=Bearer

# Static auth — set ONE of these for simple deployments:
GATEHOUSE_API_KEY=
GATEHOUSE_TOKEN=

# OAuth/OIDC token refresh — set all four for production:
GATEHOUSE_TOKEN_URL=
GATEHOUSE_CLIENT_ID=
GATEHOUSE_CLIENT_SECRET=
GATEHOUSE_TOKEN_REFRESH_MARGIN_SECONDS=60

# HTTP timeouts (seconds)
GATEHOUSE_CONNECT_TIMEOUT_SECONDS=10
GATEHOUSE_READ_TIMEOUT_SECONDS=60


# -----------------------------------------------------------------------------
# Polling loop
# -----------------------------------------------------------------------------
POLLING_ENABLED=true
POLLING_INTERVAL_SECONDS=5
POLLING_MAX_INTERVAL_SECONDS=60
POLLING_BACKOFF_FACTOR=1.5
POLLING_BATCH_SIZE=10


# -----------------------------------------------------------------------------
# Concurrency limits
# -----------------------------------------------------------------------------
CONCURRENCY_MAX_CONCURRENT_JOBS=4
CONCURRENCY_MAX_WORKER_THREADS=8


# -----------------------------------------------------------------------------
# Retry behavior
# -----------------------------------------------------------------------------
RETRY_MAX_RETRIES=3
RETRY_BASE_DELAY_SECONDS=1
RETRY_MAX_DELAY_SECONDS=30


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s [%(levelname)s] %(name)s: %(message)s
