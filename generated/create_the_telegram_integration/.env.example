# ---------------------------------------------------------------------------
# Job-Star environment template
# Copy to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------

# --- Telegram intake bot ---------------------------------------------------
# Obtain from @BotFather in Telegram.
TELEGRAM_BOT_TOKEN=

# Comma-separated allow-list of numeric Telegram user IDs permitted to submit
# intake. Leave blank to accept all DMs (not recommended for production).
TELEGRAM_ALLOWED_USER_IDS=

# Polling (dev) vs webhook (prod). Set WEBHOOK to enable webhook mode.
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PORT=8443

# --- Transcription ---------------------------------------------------------
# Used by services/telegram_bot/transcribe.py for voice notes.
OPENAI_API_KEY=
# "openai" or "whisper-local"
TRANSCRIPTION_PROVIDER=openai
WHISPER_MODEL=whisper-1

# --- Intake queue ----------------------------------------------------------
# Where parsed intake items are forwarded. "memory" for dev, "redis" for prod.
INTAKE_QUEUE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0


// --- DUPLICATE BLOCK ---

# ===========================================================================
# Job-Star Telegram Intake Bot — Environment Configuration
# ===========================================================================
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# All secrets are read from the environment; nothing is hardcoded.

# --- REQUIRED: Telegram Bot ---
# Obtain from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Comma-separated whitelist of Telegram user IDs permitted to send intake
# messages. Find your user ID via @userinfobot or similar.
# At least one ID is required; an empty whitelist rejects everyone.
TELEGRAM_ALLOWED_USER_IDS=111111111,222222222

# --- OPTIONAL: Voice Transcription ---
# If unset, the bot still accepts text messages but will reject/ignore voice.
# Either WHISPER_API_KEY or OPENAI_API_KEY enables voice transcription.
# WHISPER_API_KEY takes precedence if both are set.
# WHISPER_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# Transcription provider: 'openai' (default) or 'whisper'.
# TRANSCRIPTION_PROVIDER=openai

# Model identifier for transcription.
# TRANSCRIPTION_MODEL=whisper-1

# --- OPTIONAL: Intake Queue ---
# File path (or queue URI) where intake items are persisted for downstream
# processing. If unset, an in-memory or default path is used.
# INTAKE_QUEUE_PATH=./data/intake_queue.jsonl

# --- OPTIONAL: Runtime ---
# Log level: DEBUG, INFO, WARNING, ERROR.
# LOG_LEVEL=INFO

# Environment label for diagnostics: dev, staging, prod.
# ENVIRONMENT=dev


// --- DUPLICATE BLOCK ---

# --- Telegram polling (long-poll bootstrap) ---
TELEGRAM_POLLING_INTERVAL=1
TELEGRAM_POLLING_TIMEOUT=30
TELEGRAM_READ_TIMEOUT=35
TELEGRAM_WRITE_TIMEOUT=15
TELEGRAM_CONNECT_TIMEOUT=15
TELEGRAM_POOL_TIMEOUT=1
TELEGRAM_DROP_PENDING_UPDATES=false
TELEGRAM_ALLOWED_UPDATES=message,edited_message,channel_post
# Optional: HTTPS proxy if your environment requires it
# TELEGRAM_HTTP_PROXY=http://user:pass@host:port


// --- DUPLICATE BLOCK ---

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated allowlist of Telegram user IDs allowed to use the bot.
# Find your ID by messaging @userinfobot on Telegram.
# Example: ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=

# Path to the intake queue JSONL file
INTAKE_QUEUE_PATH=data/intake_queue.jsonl

# Whisper model size: tiny|base|small|medium|large
WHISPER_MODEL=base

# Long-polling timeout (seconds)
POLL_TIMEOUT=30


// --- DUPLICATE BLOCK ---

# --- Transcription (voice intake) ---
# Preferred: OpenAI Whisper API
OPENAI_API_KEY=
WHISPER_API_MODEL=whisper-1
# Fallback: local whisper (pip install openai-whisper)
WHISPER_LOCAL_MODEL=
# Diagnostics label only
TRANSCRIPTION_BACKEND=auto


// --- DUPLICATE BLOCK ---

# .env
TELEGRAM_BOT_TOKEN=123456789:AAH...your-token...

# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow anyone (not recommended).
TELEGRAM_ALLOWED_USER_IDS=42424242

# Storage backend for intake items. "sqlite" is the default local option.
INTAKE_STORAGE=sqlite
INTAKE_DB_PATH=./data/intake.db

# Voice transcription backend.
# "whisper-local" uses openai-whisper; "whisper-api" uses the OpenAI API.
TRANSCRIBE_BACKEND=whisper-local
OPENAI_API_KEY=sk-...            # only needed for whisper-api
